# Twilio (get from https://console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+15551234567

# Comma-separated list of phone numbers allowed to use the system (E.164)
ALLOWED_PHONE_NUMBERS=+15559876543

# Optional: path to contacts JSON (default: data/contacts.json)
# CONTACTS_PATH=./data/contacts.json

# Base URL for webhooks (required for admin "test call" - e.g. https://xxx.ngrok.io)
# BASE_URL=https://xxx.ngrok.io

# ngrok auth token (required when using docker compose ngrok service - get from https://dashboard.ngrok.com/get-started/your-authtoken)
# NGROK_AUTHTOKEN=your_ngrok_authtoken

# When running backend and frontend separately: proxy /admin to Vite (5173) so you can use one address (8000)
# ADMIN_DEV_PROXY=1
